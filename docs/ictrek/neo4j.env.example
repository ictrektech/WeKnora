# WeKnora 部署的 Neo4j / GraphRAG 环境变量示例。
#
# 把这些行复制到部署目录的 `.env`，例如：
#
#   /data/jhu/deploy/weknora/.env
#
# 不要提交真实部署 `.env`，因为里面包含密码等敏感信息。

# 开启 WeKnora 的 Neo4j client 和 GraphRAG 功能路径。
NEO4J_ENABLE=true
ENABLE_GRAPH_RAG=true

# 如果 Neo4j 使用同一个 docker compose profile 启动，并且和 app 在同一个
# Docker network 中，保持下面的 service-name URI。外部 Neo4j 则替换为 app
# 容器可访问的地址。
NEO4J_URI=bolt://neo4j:7687

# Neo4j 5.x 默认管理员用户名保持 neo4j。
NEO4J_USERNAME=neo4j

# 替换成部署专用强密码。
NEO4J_PASSWORD=replace_with_a_strong_password

# ---

# Neo4j / GraphRAG environment example for WeKnora deployments.
#
# Copy these lines into the deployment `.env` file, for example:
#
#   /data/jhu/deploy/weknora/.env
#
# Do not commit the real deployment `.env` because it contains secrets.

# Enable WeKnora's Neo4j client and GraphRAG feature path.
# NEO4J_ENABLE=true
# ENABLE_GRAPH_RAG=true

# If Neo4j runs from the bundled compose profile on the same Docker network,
# keep the service-name URI below. For an external Neo4j instance, replace this
# with the address reachable from the WeKnora app container.
# NEO4J_URI=bolt://neo4j:7687

# Neo4j 5.x expects the default admin username to remain `neo4j`.
# NEO4J_USERNAME=neo4j

# Replace this with a strong deployment-specific password.
# NEO4J_PASSWORD=replace_with_a_strong_password
