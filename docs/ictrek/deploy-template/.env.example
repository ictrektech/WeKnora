# ictrek WeKnora deployment template.
# Copy this file to `.env` in the deployment directory and edit all placeholders.

COMPOSE_PROJECT_NAME=weknora-ictrek

# Use images from the Feishu release table, not upstream wechatopenai images.
WEKNORA_APP_IMAGE=swr.cn-southwest-2.myhuaweicloud.com/ictrek/weknora:<tag>
WEKNORA_UI_IMAGE=swr.cn-southwest-2.myhuaweicloud.com/ictrek/weknora-ui:<tag>
WEKNORA_DOCREADER_IMAGE=swr.cn-southwest-2.myhuaweicloud.com/ictrek/weknora-docreader:<tag>

FRONTEND_PORT=30080
APP_PORT=30081
TZ=Asia/Shanghai
GIN_MODE=release
WEKNORA_LANGUAGE=zh-CN
DISABLE_REGISTRATION=false

DB_USER=postgres
DB_PASSWORD=<change-me>
DB_NAME=WeKnora

REDIS_PASSWORD=<change-me>
REDIS_DB=0
REDIS_PREFIX=stream:

RETRIEVE_DRIVER=postgres
STORAGE_TYPE=local
LOCAL_STORAGE_BASE_DIR=/data/files
STREAM_MANAGER_TYPE=redis

# Model backends are not baked into images. Add models in the UI, or mount
# config/builtin_models.yaml intentionally.
OLLAMA_BASE_URL=http://host.docker.internal:11434
SSRF_WHITELIST=
SSRF_WHITELIST_EXTRA=host.docker.internal,searxng,qdrant,milvus,weaviate,doris-fe

CONCURRENCY_POOL_SIZE=4
WEKNORA_ASYNQ_CONCURRENCY=2
WEKNORA_MAIN_QA_MODEL_CONCURRENCY=4
WEKNORA_CHAT_RESERVED_CONCURRENCY=2
WEKNORA_GRAPH_LLM_CONCURRENCY=2
WEKNORA_WIKI_INGEST_MAP_PARALLEL=2
WEKNORA_WIKI_INGEST_REDUCE_PARALLEL=2
WEKNORA_ASYNQ_QUEUE_CRITICAL=10
WEKNORA_ASYNQ_QUEUE_PARSE=5
WEKNORA_ASYNQ_QUEUE_DEFAULT=4
WEKNORA_ASYNQ_QUEUE_LOW=1
WEKNORA_ASYNQ_QUEUE_MULTIMODAL=3
WEKNORA_ASYNQ_QUEUE_GRAPH=1
WEKNORA_ASYNQ_QUEUE_QUESTION=2
WEKNORA_REPARSE_INCOMPLETE_ON_START=true
WEKNORA_REPARSE_WAIT_URLS=
WEKNORA_REPARSE_READY_WAIT_SECONDS=300
MAX_FILE_SIZE_MB=500

# Optional bootstrap. Leave empty unless you want the app to grant system admin
# to an existing or newly-created account on startup.
WEKNORA_BOOTSTRAP_SYSTEM_ADMIN_EMAIL=

# Optional secrets. If left empty, WeKnora generates runtime crypto state under
# /data/files; keep data/files persistent.
JWT_SECRET=
TENANT_AES_KEY=
SYSTEM_AES_KEY=
CRYPTO_MASTER_KEY=
CRYPTO_SALT=

# Optional GraphRAG / Wiki Graph.
ENABLE_GRAPH_RAG=false
NEO4J_ENABLE=false
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<change-me-if-neo4j-enabled>
# Host-published ports intentionally avoid Neo4j defaults 7474/7687.
# Keep NEO4J_URI=bolt://neo4j:7687 when app and neo4j are in this compose project.
NEO4J_HTTP_PORT=17474
NEO4J_BOLT_PORT=17687

# Optional docreader tuning.
DOCREADER_PDF_FORCE_SCANNED=false
DOCREADER_ODL_MAX_WORKERS=1
DOCREADER_ODL_HYBRID=off
DOCREADER_MARKITDOWN_MAX_WORKERS=1
DOCREADER_PDF_RENDER_MAX_WORKERS=1
DOCREADER_PDF_RENDER_DPI=200
DOCREADER_PDF_JPEG_QUALITY=90
GRPC_TLS_ENABLED=false
GRPC_AUTH_TOKEN=
