# ictrek WeKnora Orin NX / L4T 纯 Ollama 部署 overlay。
# 和 .env.example 一起使用：
#   cp .env.example .env
#   cp .env.orin-ollama.example .env.orin-ollama
#   docker compose --env-file .env -f docker-compose.yml -f docker-compose.orin-ollama.yml config
#
# 本文件只放和基础模板不同的值，以及 docker-compose.orin-ollama.yml 需要的值。

COMPOSE_PROJECT_NAME=weknora-orin-ollama

# 使用飞书发布表中的 ARM/L4T 已发布镜像。
WEKNORA_APP_IMAGE=swr.cn-southwest-2.myhuaweicloud.com/ictrek/weknora:<arm-or-l4t-tag>
WEKNORA_UI_IMAGE=swr.cn-southwest-2.myhuaweicloud.com/ictrek/weknora-ui:<arm-or-l4t-tag>
WEKNORA_DOCREADER_IMAGE=swr.cn-southwest-2.myhuaweicloud.com/ictrek/weknora-docreader:<arm-or-l4t-tag>

FRONTEND_PORT=19080
APP_PORT=19081

# L4T Ollama 镜像包含 Ollama 和 11535 端口上的 OpenAI-compatible gateway。
# 这是 WeKnora 外部模型后端，不由 WeKnora 镜像构建流程构建。
OLLAMA_SERVER_IMAGE=swr.cn-southwest-2.myhuaweicloud.com/ictrek/ollama_server:l4t_0.30.7

# 分离 Ollama 服务。QA/VLM 和 Embedding 不在同一个 Ollama 调度器中竞争，
# 文档索引不会消耗聊天模型槽位。
OLLAMA_QA_HOST_PORT=21434
OLLAMA_QA_GATEWAY_HOST_PORT=21535
OLLAMA_EMBEDDING_HOST_PORT=21435
OLLAMA_EMBEDDING_GATEWAY_HOST_PORT=21536
OLLAMA_QA_MODELS_DIR=/data/jhu/models/ollama-qa
OLLAMA_EMBEDDING_MODELS_DIR=/data/jhu/models/ollama-embedding

OLLAMA_QA_MODEL=qwen3.5:2b
OLLAMA_EMBEDDING_MODEL=bge-m3:latest
OLLAMA_KEEP_ALIVE=-1
OLLAMA_CONTEXT_LENGTH=18000

# Orin NX 16G 起步值。QA 上下文必须大于 16k，不能正好 16k；先用 18000。
# 如果排队或 OOM，先降 Graph/Wiki/embedding 和后台 worker，不要降聊天预留。
OLLAMA_QA_NUM_PARALLEL=3
OLLAMA_EMBEDDING_NUM_PARALLEL=4

# 应用侧容量。3 个 QA 槽里保留 2 个给聊天，后台增强只拿 1 个。
WEKNORA_MAIN_QA_MODEL_CONCURRENCY=3
WEKNORA_CHAT_RESERVED_CONCURRENCY=2
WEKNORA_GRAPH_LLM_CONCURRENCY=1
WEKNORA_WIKI_INGEST_MAP_PARALLEL=1
WEKNORA_WIKI_INGEST_REDUCE_PARALLEL=1
WEKNORA_ASYNQ_CONCURRENCY=1
WEKNORA_WIKI_ASYNQ_CONCURRENCY=1
WEKNORA_MODEL_MAX_CONCURRENCY=1
WEKNORA_ASYNQ_QUEUE_CRITICAL=10
WEKNORA_ASYNQ_QUEUE_DEFAULT=3
WEKNORA_ASYNQ_QUEUE_LOW=1
WEKNORA_ASYNQ_QUEUE_MULTIMODAL=1
WEKNORA_ASYNQ_QUEUE_GRAPH=1
WEKNORA_ASYNQ_QUEUE_QUESTION=2
WEKNORA_REPARSE_WAIT_URLS=http://ollama-qa:11535/v1/models,http://ollama-embedding:11535/v1/models
WEKNORA_REPARSE_READY_WAIT_SECONDS=300

# Embedding 隔离主要来自单独的 ollama-embedding 容器。
# Orin NX 上应用侧文档 embedding 并发不要太高。
CONCURRENCY_POOL_SIZE=1
BATCH_EMBED_SIZE=4

# 本地 Ollama 状态页使用 QA 容器。分离模型行应使用 source=remote，
# 并使用 builtin_models.orin-ollama.yaml.example 中的 gateway URL。
OLLAMA_BASE_URL=http://ollama-qa:11434
SSRF_WHITELIST_EXTRA=ollama-qa,ollama-embedding,host.docker.internal,searxng,qdrant,milvus,weaviate,doris-fe
